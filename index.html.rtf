        </div>\
        <div class="footer">\
            Powered by DailyVerses.net\
        </div>\
    </div>\
\
    <script>\
        // Function to fetch verse using a public API\
        async function fetchVerse() \{\
            try \{\
                // Using a common Bible API for reliable JSON data\
                const response = await fetch('https://labs.bible.org/api/?passage=random&type=json');\
                const data = await response.json();\
                \
                const verse = data[0];\
                document.querySelector('.verse-text').innerText = `"$\{verse.text\}"`;\
                document.querySelector('.verse-ref').innerText = `$\{verse.bookname\} $\{verse.chapter\}:$\{verse.verse\}`;\
            \} catch (error) \{\
                document.querySelector('.verse-text').innerText = "Stay positive and keep moving forward.";\
                document.querySelector('.verse-ref').innerText = "- Daily Wisdom";\
            \}\
        \}\
\
        fetchVerse();\
    </script>\
