            font-size: 1.5rem;\
            color: var(--primary-color);\
            margin-bottom: 20px;\
            line-height: 1.6;\
        \}\
        .verse-ref \{\
            font-weight: bold;\
            color: var(--accent-color);\
            text-transform: uppercase;\
            letter-spacing: 1px;\
        \}\
